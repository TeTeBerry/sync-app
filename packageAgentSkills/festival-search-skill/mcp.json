{
  "apis": [
    {
      "name": "searchFestivals",
      "description": "检索电音节活动列表与资讯（纯文本检索，不渲染卡片）。返回匹配的活动列表，包含名称、时间、地点、legacyId。如需展示卡片，用 getEvent 按 legacyId 拉取详情渲染 search-results-card。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "检索意图，如节名、艺人、时间或地点，例如 EDC Korea"
          },
          "homeCity": {
            "type": "string",
            "description": "用户出发城市，可选"
          }
        },
        "required": ["query"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "totalMatched": { "type": "number" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "legacyId": { "type": "number" },
                "name": { "type": "string" },
                "date": { "type": "string" },
                "location": { "type": "string" },
                "heroImageUrl": { "type": "string" }
              }
            }
          },
          "canonicalActivityName": { "type": "string" },
          "searchSnapshot": { "type": "object" },
          "uiDirectives": { "type": "array" }
        }
      }
    },
    {
      "name": "getEvent",
      "description": "获取单场电音节活动详情（非票务），渲染 search-results-card 展示活动信息",
      "_meta": {
        "ui": {
          "componentPath": "components/search-results-card/index"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "activityLegacyId": {
            "type": "number",
            "description": "活动 legacyId"
          }
        },
        "required": ["activityLegacyId"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "legacyId": { "type": "number" },
          "name": { "type": "string" },
          "canonicalActivityName": { "type": "string" },
          "date": { "type": "string" },
          "location": { "type": "string" },
          "lineupPublished": { "type": "boolean" },
          "heroImageUrl": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "legacyId": { "type": "number" },
                "name": { "type": "string" },
                "date": { "type": "string" },
                "location": { "type": "string" },
                "heroImageUrl": { "type": "string" },
                "lineupPublished": { "type": "boolean" }
              }
            }
          },
          "totalMatched": { "type": "number" },
          "activity": { "type": "object" },
          "uiDirectives": { "type": "array" }
        }
      }
    },
    {
      "name": "getLineup",
      "description": "获取活动官宣阵容艺人列表",
      "_meta": {
        "ui": {
          "componentPath": "components/artist-lineup-strip/index"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "activityLegacyId": {
            "type": "number",
            "description": "活动 legacyId"
          }
        },
        "required": ["activityLegacyId"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "activityLegacyId": { "type": "number" },
          "activityName": { "type": "string" },
          "canonicalActivityName": { "type": "string" },
          "activityDate": { "type": "string" },
          "activityLocation": { "type": "string" },
          "activity": { "type": "object" },
          "artists": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "imageUrl": { "type": "string" }
              }
            }
          },
          "uiDirectives": { "type": "array" }
        }
      }
    }
  ],
  "components": [
    {
      "path": "components/search-results-card/index",
      "relatedPage": "/packageEvent/pages/event-detail/index"
    },
    {
      "path": "components/artist-lineup-strip/index",
      "relatedPage": "/packageEvent/pages/event-detail/index"
    }
  ]
}
