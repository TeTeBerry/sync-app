@import '../../../shared/cardTokens.wxss';

.recruit-list-card {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.recruit-list-card-event {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-bottom: 0;
}

.recruit-list-card-event-cover {
  width: 68rpx;
  height: 68rpx;
  margin-right: 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.recruit-list-card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-top: 12rpx;
}

.recruit-list-card-avatar {
  width: 64rpx;
  height: 64rpx;
  margin-right: 16rpx;
  background: rgba(255, 0, 102, 0.12);
}

.recruit-list-card-meta {
  min-width: 0;
}

.recruit-list-card-summary {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recruit-list-card-chips-scroll {
  width: 100%;
  white-space: nowrap;
}

.recruit-list-card-chips-row {
  display: flex;
  flex-direction: row;
  padding-top: 10rpx;
  padding-bottom: 0;
}

.recruit-list-card-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}

.recruit-list-card-empty-kicker {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.38);
  margin-bottom: 14rpx;
}

.recruit-list-card-empty-msg {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.72);
  margin-bottom: 10rpx;
}

.recruit-list-card-empty-hint {
  display: block;
  font-size: 24rpx;
  line-height: 1.4;
  color: rgba(255, 255, 255, 0.4);
}

.recruit-list-card-main {
  flex: 1;
  min-height: 0;
  padding-top: 12rpx;
}

.recruit-list-card-more {
  display: block;
  margin-top: 12rpx;
}

@media (prefers-color-scheme: dark) {
  .recruit-list-card {
    color: #ffffff;
  }
}
