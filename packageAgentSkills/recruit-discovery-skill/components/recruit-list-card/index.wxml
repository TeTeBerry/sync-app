<view class="recruit-list-card card-surface-list card-aspect-16-9" hover-class="card-hover" bindtap="onTap">
  <view class="card-accent-bar" />
  <view class="recruit-list-card-event search-results-card event-card event-card--embedded card-pad">
    <image
      wx:if="{{activityHeroImageUrl}}"
      class="recruit-list-card-event-cover"
      src="{{activityHeroImageUrl}}"
      mode="aspectFill"
    />
    <view class="card-col card-body-grow">
      <text class="card-kicker">EVENT</text>
      <text class="card-title card-ellipsis-1">{{activityName || '活动招募'}}</text>
      <text wx:if="{{activityMeta}}" class="card-meta card-ellipsis-1">{{activityMeta}}</text>
    </view>
  </view>
  <scroll-view
    scroll-x="true"
    wx:if="{{hasFilterBar}}"
    class="recruit-list-card-chips-scroll"
    enable-flex
  >
    <view class="recruit-list-card-chips-row card-pad">
      <text wx:for="{{filterLabels}}" wx:key="*this" class="card-chip card-chip--ai">{{item}}</text>
      <text class="card-chip">{{sortLabel}}</text>
    </view>
  </scroll-view>
  <view wx:if="{{isEmpty}}" class="recruit-list-card-empty card-pad">
    <text class="recruit-list-card-empty-kicker">公开招募</text>
    <text class="recruit-list-card-empty-msg">{{emptyMessage}}</text>
    <text class="recruit-list-card-empty-hint">可点击卡片进入小程序查看完整招募墙</text>
  </view>
  <block wx:else>
    <view class="recruit-list-card-main card-pad">
      <text class="card-kicker">队友招募</text>
      <view class="recruit-list-card-header">
        <image class="card-avatar recruit-list-card-avatar" src="{{post.avatarUrl}}" mode="aspectFill" />
        <view class="recruit-list-card-meta card-body-grow">
          <text class="card-subtitle card-ellipsis-1">{{post.nickname}}</text>
          <view class="card-quote-panel">
            <text class="card-body recruit-list-card-summary">{{post.summary}}</text>
          </view>
        </view>
      </view>
      <text wx:if="{{moreCount > 0}}" class="card-more recruit-list-card-more">还有 {{moreCount}} 条招募</text>
    </view>
  </block>
  <view class="card-foot-bar-col">
    <text class="card-disclaimer">平台不保证组满 · 公开招募</text>
  </view>
</view>
