<view
  class="prep-status-card card-surface-list card-aspect-16-9 {{statusTone}}"
  hover-class="card-hover"
  bindtap="onTap"
>
  <view class="card-accent-bar" />
  <view class="prep-status-card-inner card-pad">
    <view class="card-header-row">
      <text class="card-kicker">观演准备</text>
      <text class="card-status-chip {{statusChipClass}}">{{statusLabel}}</text>
    </view>
    <text wx:if="{{activityName}}" class="card-title card-line-clamp-2">{{activityName}}</text>
    <text wx:if="{{detailText}}" class="card-body prep-status-card-detail">{{detailText}}</text>
    <view wx:if="{{wechatHint}}" class="card-info-callout">
      <text class="card-text-secondary">{{wechatHint}}</text>
    </view>
  </view>
  <view class="card-foot-bar">
    <text class="card-disclaimer">AI 内容仅供参考</text>
    <view class="card-cta-pill prep-status-card-cta">
      <text class="card-cta-pill-text">{{ctaLabel}}</text>
    </view>
  </view>
</view>
