{
  "apis": [
    {
      "name": "draftRecruitPost",
      "description": "生成招募帖草稿，须用户进入小程序确认后发布（无 publish 接口）",
      "_meta": {
        "ui": {
          "componentPath": "components/draft-candidates-card/index"
        }
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "activityLegacyId": {
            "type": "number",
            "description": "活动 legacyId"
          },
          "draft": {
            "type": "object",
            "description": "发帖表单：dateStart、dateEnd、location、headcount",
            "properties": {
              "dateStart": { "type": "string", "description": "出发日期 YYYY-MM-DD" },
              "dateEnd": { "type": "string", "description": "返程日期 YYYY-MM-DD" },
              "location": { "type": "string", "description": "出发地" },
              "headcount": { "type": "string", "description": "人数，如 2 或 2-3" }
            },
            "required": ["dateStart", "dateEnd", "location", "headcount"]
          }
        },
        "required": ["activityLegacyId", "draft"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "artifactId": { "type": "string" },
          "preview": { "type": "object" }
        }
      }
    }
  ],
  "components": [
    {
      "path": "components/draft-candidates-card/index",
      "relatedPage": "/packageEvent/pages/event-detail/index"
    }
  ]
}
