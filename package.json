{
  "name": "sync-app",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev:h5": "taro build --type h5 --watch",
    "predev:weapp": "node scripts/sync-weapp-env.mjs && node scripts/sync-weapp-project-config.mjs",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "prebuild:weapp": "node scripts/sync-weapp-env.mjs && node scripts/sync-weapp-project-config.mjs",
    "build:weapp": "taro build --type weapp",
    "clean:weapp": "rm -rf dist-weapp",
    "build:weapp:size": "npm run build:weapp && npm run size:weapp",
    "size:weapp": "node scripts/size-weapp.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"config/**/*.{ts,js}\" vitest.config.ts",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\" \"config/**/*.{ts,js}\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss}\" \"config/**/*.{ts,js}\" \"vitest.config.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{scss,js,mjs}": ["prettier --write"],
    "config/**/*.{ts,js}": ["eslint --fix", "prettier --write"],
    "vitest.config.ts": ["eslint --fix", "prettier --write"]
  },
  "dependencies": {
    "@babel/runtime": "^7.27.6",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-html": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "dayjs": "^1.11.21",
    "lucide-react-taro": "^1.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.13"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/node": "^22.13.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "babel-preset-taro": "4.2.0",
    "cssnano": "^7.1.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "sass": "^1.93.3",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4",
    "webpack": "5.91.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  }
}
