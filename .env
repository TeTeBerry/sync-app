# H5 开发走 devServer 代理（config/index.ts → localhost:3000）
TARO_APP_API_BASE_URL=/api
# H5 dev: devServer proxies /api (incl. WS) → localhost:3000
TARO_APP_WS_URL=ws://127.0.0.1:10086/api/ai/chat/ws
# Weapp 真机: 用局域网 IP，并在开发者工具勾选「不校验合法域名」
# TARO_APP_API_BASE_URL=http://192.168.1.10:3000/api
# TARO_APP_WS_URL=ws://192.168.1.10:3000/api/ai/chat/ws
