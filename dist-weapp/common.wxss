.s-post-image-grid {
  display: grid;
  gap: 12rpx;
  margin: 24rpx 0 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-width: 0;
}

.s-post-image-grid__item,
.s-post-image-grid__featured,
.s-post-image-grid__thumb {
  position: relative;
  padding: 0;
  border: none;
  background: #1c1c1e;
  overflow: hidden;
  display: block;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-width: 0;
}

.s-post-image-grid__item:active,
.s-post-image-grid__featured:active,
.s-post-image-grid__thumb:active {
  opacity: 0.85;
}

.s-post-image-grid__img {
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  height: 100%;
  display: block;
}

.s-post-image-grid__more {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

/* Image count badge (top-right of featured image, like screenshot) */

.s-post-image-grid__count-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 19998rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  backdrop-filter: blur(8rpx);
}

/* ---------- 1-3 images: grid layout ---------- */

/* 1 image: full width, 16:10 ratio */

.s-post-image-grid--1 {
  grid-template-columns: 1fr;
  aspect-ratio: 16/10;
}

/* 2 images: side by side, 1:1 each */

.s-post-image-grid--2 {
  grid-template-columns: 1fr 1fr;
  aspect-ratio: 2/1;
}

.s-post-image-grid--2 .s-post-image-grid__item {
  aspect-ratio: 1/1;
}

/* 3 images: row of 3 */

.s-post-image-grid--3 {
  grid-template-columns: repeat(3, 1fr);
  aspect-ratio: 3/1;
}

.s-post-image-grid--3 .s-post-image-grid__item {
  aspect-ratio: 1/1;
}

/* ---------- 4+ images: featured + thumbnails (screenshot style) ---------- */

.s-post-image-grid--featured {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  aspect-ratio: unset;
}

.s-post-image-grid__featured {
  position: relative;
  width: 100%;
  aspect-ratio: 16/10;
  border-radius: 24rpx;
  overflow: hidden;
}

.s-post-image-grid__thumbs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-width: 0;
}

.s-post-image-grid__thumb {
  position: relative;
  aspect-ratio: 1/1;
  border-radius: 24rpx;
  overflow: hidden;
}

/* Image count badge in post header (legacy, kept for EventPostCard header) */

.s-post-image-count {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #8e8e93;
  vertical-align: middle;
}
