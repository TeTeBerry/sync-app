.s-event-detail {
  background: #000;
  color: #fff;
  box-sizing: border-box;
}

.s-event-detail__main {
  width: 100%;
  box-sizing: border-box;
}

.s-event-detail__scroll-inner {
  width: 100%;
  box-sizing: border-box;
}

.s-event-detail__header {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx 20rpx;
}

.s-event-detail__back {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border: none;
  background: transparent;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.s-event-detail__head-main {
  min-width: 0;
  text-align: center;
}

.s-event-detail__title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  min-width: 0;
}

.s-event-detail__title {
  margin: 0;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.s-event-detail__meta {
  margin: 8rpx 0 0;
  font-size: 24rpx;
  color: #8e8e93;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.s-event-detail__map-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  border: none;
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.s-event-detail__ai {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #1c1c1e;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.s-event-detail__ai-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.s-event-detail__ai-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 0;
}

.s-event-detail__ai-tag {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  background: transparent;
  color: rgba(255, 255, 255, 0.42);
  font-size: 22rpx;
  font-weight: 500;
  transition: color 0.15s ease, border-color 0.15s ease;
}

.s-event-detail__ai-tag:hover, .s-event-detail__ai-tag:active {
  color: rgba(255, 255, 255, 0.62);
  border-color: rgba(255, 255, 255, 0.18);
}

.s-event-detail__ai-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 16rpx 16rpx 28rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  color-scheme: dark;
}

.s-event-detail__ai-input__field {
  flex: 1;
  min-width: 0;
  border: none;
  background: none;
  background-color: transparent;
  -webkit-appearance: none;
  appearance: none;
  color: #fff;
  font-size: 26rpx;
  outline: none;
  box-shadow: none;
}

.s-event-detail__ai-input__field:focus {
  background: none;
  background-color: transparent;
}

.s-event-detail__ai-input__field:-webkit-autofill, .s-event-detail__ai-input__field:-webkit-autofill:hover, .s-event-detail__ai-input__field:-webkit-autofill:focus {
  box-shadow: 0 0 0 2000rpx rgb(28, 28, 30) inset;
  -webkit-text-fill-color: #fff;
  caret-color: #fff;
  -webkit-transition: background-color 9999s ease-out;
  transition: background-color 9999s ease-out;
}

.s-event-detail__ai-input__field::placeholder {
  color: #8e8e93;
}

.s-event-detail__ai-send {
  width: 80rpx;
  height: 80rpx;
  padding: 0;
  border-radius: var(--radius-full);
  border: none;
  background: var(--primary);
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.s-event-detail__ai-send .h5-svg {
  width: 40rpx;
  height: 40rpx;
}

.s-event-detail__posts {
  display: flex;
  flex-direction: column;
}

.s-event-post {
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #1c1c1e;
}

.s-event-post--highlight {
  background: rgba(255, 214, 10, 0.08);
  box-shadow: inset 6rpx 0 0 #ffd60a;
}

.s-event-post__header {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.s-event-post__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-full);
  object-fit: cover;
  flex-shrink: 0;
}

.s-event-post__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
}

.s-event-post__head-main {
  flex: 1;
  min-width: 0;
}

.s-event-post__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 4rpx;
}

.s-event-post__user-line {
  margin: 0;
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.s-event-post__user-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #fff;
}

.s-event-post__user-meta {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.s-event-post__meta {
  font-size: 24rpx;
  color: #8e8e93;
}

.s-event-post__text {
  margin: 0 0 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.92);
}

.s-event-post__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.s-event-post__tag {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  background: rgba(100, 210, 255, 0.12);
  color: #64d2ff;
  font-size: 24rpx;
  font-weight: 700;
}

.s-event-post__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.s-event-post__actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  color: var(--s-post-action-icon);
  font-size: 26rpx;
}

.s-event-post__action {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 0;
  border: none;
  background: transparent;
  color: var(--s-post-action-icon);
  font: inherit;
}

.s-event-post__action--active {
  color: var(--s-post-action-active);
}

.s-event-post__action--liked {
  color: var(--s-post-action-liked);
}

.s-event-post__action--complete {
  color: #34c759;
  font-size: 24rpx;
  font-weight: 600;
  gap: 6rpx;
}

.s-event-post__apply {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  border-radius: var(--radius-full);
  border: none;
  background: var(--primary);
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 0 20rpx rgba(var(--primary-rgb), 0.45);
  white-space: nowrap;
}

.s-event-post__apply--done {
  background: #333;
  color: #ccc;
  box-shadow: none;
}

.s-event-detail__end {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 32rpx;
  text-align: center;
  color: #8e8e93;
  font-size: 26rpx;
}

.s-event-detail__empty {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #8e8e93;
  font-size: 28rpx;
}

.s-event-detail__fallback {
  padding: 96rpx 32rpx;
  text-align: center;
  color: #8e8e93;
}

.s-event-detail__retry {
  margin-top: 24rpx;
  color: var(--primary, #a855f7);
  background: none;
  border: none;
  font-size: 28rpx;
}
