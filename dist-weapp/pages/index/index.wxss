.s-page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 48rpx 32rpx;
}

.s-page-loading__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary, #ff2d55);
  opacity: 0.35;
  animation: s-page-loading-pulse 1s ease-in-out infinite;
}

.s-page-loading__dot:nth-child(2) {
  animation-delay: 0.15s;
}

.s-page-loading__dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes s-page-loading-pulse {
  0%, 100% {
    opacity: 0.35;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.15);
  }
