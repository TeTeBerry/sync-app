.s-posts-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
  color: var(--foreground);
}

.s-posts-page__main {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}

.s-posts-page__state {
  padding: 96rpx 32rpx;
  text-align: center;
  color: var(--muted-foreground);
  font-size: 28rpx;
}

.s-posts-page__retry {
  margin-top: 24rpx;
  color: var(--primary);
  background: none;
  border: none;
  font-size: 28rpx;
}
