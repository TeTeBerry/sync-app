:root,page{--nut-scale-f:1;--nut-scale-font:var(--nut-scale-f,1);--nut-scale-icon:var(--nut-scale-f,1);--nut-icon-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-width:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-line-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important}.s-posts-page{background:#000;color:var(--foreground);display:flex;flex-direction:column;min-height:100vh}.s-posts-page__main{box-sizing:border-box;flex:1;min-height:0;width:100%}.s-posts-page__state{color:var(--muted-foreground);font-size:28rpx;padding:96rpx 32rpx;text-align:center}.s-posts-page__retry{background:none;border:none;color:var(--primary);font-size:28rpx;margin-top:24rpx}