:root,page{--nut-scale-f:1;--nut-scale-font:var(--nut-scale-f,1);--nut-scale-icon:var(--nut-scale-f,1);--nut-icon-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-width:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-line-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important}.s-settings{background-color:var(--background);display:flex;flex-direction:column;min-height:100vh;width:100%}.s-settings__main{flex:1;padding:32rpx}.s-settings__card{background:rgba(30,30,30,.9);border-radius:var(--radius-2xl);box-shadow:inset 0 0 0 2rpx hsla(0,0%,100%,.06);overflow:hidden}.s-settings__row{align-items:center;display:flex;gap:24rpx;justify-content:space-between;padding:32rpx}.s-settings__row:not(:last-child){border-bottom:2rpx solid hsla(0,0%,100%,.06)}.s-settings__row-label{color:#fff;font-size:30rpx;font-weight:500}.s-settings__row-desc{color:var(--muted-foreground);font-size:24rpx;margin-top:4rpx}.s-settings__toggle{background:hsla(0,0%,100%,.15);border:none;border-radius:19998rpx;flex-shrink:0;height:56rpx;position:relative;transition:background .2s ease;width:96rpx;-webkit-tap-highlight-color:transparent}.s-settings__toggle--on{background:var(--primary)}.s-settings__toggle-knob{background:#fff;border-radius:19998rpx;height:44rpx;left:6rpx;position:absolute;top:6rpx;transition:transform .2s ease;width:44rpx}.s-settings__toggle--on .s-settings__toggle-knob{transform:translateX(40rpx)}.s-settings__option{align-items:center;background:transparent;border:none;display:flex;justify-content:space-between;padding:32rpx;text-align:left;width:100%;-webkit-tap-highlight-color:transparent}.s-settings__option:not(:last-child){border-bottom:2rpx solid hsla(0,0%,100%,.06)}.s-settings__option:active{background:hsla(0,0%,100%,.04)}.s-settings__option--selected .s-settings__option-label{color:var(--primary)}.s-settings__option-label{color:#fff;font-size:30rpx;font-weight:500}.s-settings__option-desc{color:var(--muted-foreground);font-size:24rpx;margin-top:4rpx}.s-settings__check{color:var(--primary);flex-shrink:0}.s-settings__faq{margin-top:32rpx}.s-settings__faq-title{color:var(--muted-foreground);font-size:26rpx;font-weight:600;margin-bottom:24rpx;padding-left:8rpx}.s-settings__faq-item{padding:32rpx}.s-settings__faq-item:not(:last-child){border-bottom:2rpx solid hsla(0,0%,100%,.06)}.s-settings__faq-q{color:#fff;font-size:28rpx;font-weight:600;margin-bottom:12rpx}.s-settings__faq-a{color:var(--muted-foreground);font-size:26rpx;line-height:1.5}.s-settings__feedback-btn{background:var(--primary);border:none;border-radius:var(--radius-2xl);color:#fff;display:block;font-size:30rpx;font-weight:600;margin-top:40rpx;padding:28rpx;width:100%;-webkit-tap-highlight-color:transparent}.s-settings__feedback-btn:active{opacity:.85}