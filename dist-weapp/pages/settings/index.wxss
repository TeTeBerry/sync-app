.s-settings {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background);
}

.s-settings__main {
  flex: 1;
  padding: 32rpx;
}

.s-settings__card {
  border-radius: var(--radius-2xl);
  background: rgba(30, 30, 30, 0.9);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.06);
  overflow: hidden;
}

.s-settings__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  gap: 24rpx;
}

.s-settings__row:not(:last-child) {
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.06);
}

.s-settings__row-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
}

.s-settings__row-desc {
  font-size: 24rpx;
  color: var(--muted-foreground);
  margin-top: 4rpx;
}

.s-settings__toggle {
  position: relative;
  width: 96rpx;
  height: 56rpx;
  border-radius: 19998rpx;
  border: none;
  background: rgba(255, 255, 255, 0.15);
  flex-shrink: 0;
  transition: background 200ms ease;
  -webkit-tap-highlight-color: transparent;
}

.s-settings__toggle--on {
  background: var(--primary);
}

.s-settings__toggle-knob {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 19998rpx;
  background: #fff;
  transition: transform 200ms ease;
}

.s-settings__toggle--on .s-settings__toggle-knob {
  transform: translateX(40rpx);
}

.s-settings__option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 32rpx;
  border: none;
  background: transparent;
  text-align: left;
  -webkit-tap-highlight-color: transparent;
}

.s-settings__option:not(:last-child) {
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.06);
}

.s-settings__option:active {
  background: rgba(255, 255, 255, 0.04);
}

.s-settings__option--selected .s-settings__option-label {
  color: var(--primary);
}

.s-settings__option-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
}

.s-settings__option-desc {
  font-size: 24rpx;
  color: var(--muted-foreground);
  margin-top: 4rpx;
}

.s-settings__check {
  color: var(--primary);
  flex-shrink: 0;
}

.s-settings__faq {
  margin-top: 32rpx;
}

.s-settings__faq-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--muted-foreground);
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.s-settings__faq-item {
  padding: 32rpx;
}

.s-settings__faq-item:not(:last-child) {
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.06);
}

.s-settings__faq-q {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.s-settings__faq-a {
  font-size: 26rpx;
  color: var(--muted-foreground);
  line-height: 1.5;
}

.s-settings__feedback-btn {
  display: block;
  width: 100%;
  margin-top: 40rpx;
  padding: 28rpx;
  border: none;
  border-radius: var(--radius-2xl);
  background: var(--primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  -webkit-tap-highlight-color: transparent;
}

.s-settings__feedback-btn:active {
  opacity: 0.85;
}
