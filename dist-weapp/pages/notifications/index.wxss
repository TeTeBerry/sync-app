.s-notifications {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--background);
}

.s-notifications__main {
  flex: 1;
  padding: 32rpx;
}

.s-notifications__tabs {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  margin-bottom: 24rpx;
  padding-bottom: 8rpx;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.s-notifications__tabs::-webkit-scrollbar {
  display: none;
}

.s-notifications__tab {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  border: none;
  border-radius: 19998rpx;
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  font-weight: 500;
  -webkit-tap-highlight-color: transparent;
}

.s-notifications__tab--active {
  background: rgba(255, 0, 102, 0.18);
  color: var(--primary);
  box-shadow: inset 0 0 0 2rpx rgba(255, 0, 102, 0.35);
}

.s-notifications__tab-count {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 19998rpx;
  background: rgba(255, 255, 255, 0.1);
  font-size: 22rpx;
  line-height: 36rpx;
  text-align: center;
}

.s-notifications__tab--active .s-notifications__tab-count {
  background: rgba(255, 0, 102, 0.25);
}

.s-notifications__toolbar {
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.s-notifications__toolbar-btn {
  border: none;
  background: transparent;
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 0;
  -webkit-tap-highlight-color: transparent;
}

.s-notifications__toolbar-btn:disabled {
  opacity: 0.4;
}

.s-notifications__list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.s-notifications__item {
  display: flex;
  gap: 8rpx;
  align-items: stretch;
  width: 100%;
  border-radius: var(--radius-2xl);
  background: rgba(30, 30, 30, 0.9);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.06);
  position: relative;
}

.s-notifications__item--unread {
  box-shadow: inset 6rpx 0 0 var(--primary), inset 0 0 0 2rpx rgba(255, 255, 255, 0.06);
}

.s-notifications__item-main {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
  text-align: left;
  padding: 28rpx 16rpx 28rpx 24rpx;
  border: none;
  background: transparent;
  -webkit-tap-highlight-color: transparent;
}

.s-notifications__item-main:active {
  opacity: 0.88;
}

.s-notifications__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.s-notifications__icon--pindan {
  background: rgba(255, 0, 102, 0.15);
  color: var(--primary);
}

.s-notifications__icon--like {
  background: rgba(255, 105, 180, 0.15);
  color: #ff69b4;
}

.s-notifications__icon--comment {
  background: rgba(76, 201, 240, 0.15);
  color: var(--secondary);
}

.s-notifications__icon--system {
  background: rgba(255, 193, 7, 0.15);
  color: #ffc107;
}

.s-notifications__icon--general {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.72);
}

.s-notifications__icon--ticket {
  background: rgba(76, 201, 240, 0.15);
  color: var(--secondary);
}

.s-notifications__content {
  flex: 1;
  min-width: 0;
}

.s-notifications__title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.s-notifications__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.s-notifications__time {
  font-size: 22rpx;
  color: var(--muted-foreground);
  flex-shrink: 0;
}

.s-notifications__body {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.72);
}

.s-notifications__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 19998rpx;
  background: var(--primary);
  flex-shrink: 0;
  margin-top: 12rpx;
}

.s-notifications__delete {
  flex-shrink: 0;
  align-self: center;
  border: none;
  background: transparent;
  color: rgba(255, 255, 255, 0.35);
  padding: 28rpx 24rpx 28rpx 12rpx;
  -webkit-tap-highlight-color: transparent;
}

.s-notifications__delete:active {
  color: rgba(var(--destructive-rgb), 0.92);
}

.s-notifications__empty {
  padding: 96rpx 32rpx;
  text-align: center;
  color: var(--muted-foreground);
}

.s-notifications__empty-icon {
  margin: 0 auto 24rpx;
  opacity: 0.5;
}

.s-notifications__empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
}

.s-notifications__empty-desc {
  font-size: 26rpx;
}

.s-notifications__loading {
  padding: 64rpx;
  text-align: center;
  color: var(--muted-foreground);
  font-size: 28rpx;
}
