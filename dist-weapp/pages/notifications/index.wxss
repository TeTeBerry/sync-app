:root,page{--nut-scale-f:1;--nut-scale-font:var(--nut-scale-f,1);--nut-scale-icon:var(--nut-scale-f,1);--nut-icon-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-width:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-line-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important}.s-notifications{background:var(--background);display:flex;flex-direction:column;min-height:100vh}.s-notifications__main{flex:1;padding:32rpx}.s-notifications__tabs{display:flex;gap:16rpx;margin-bottom:24rpx;overflow-x:auto;padding-bottom:8rpx;-webkit-overflow-scrolling:touch;scrollbar-width:none}.s-notifications__tabs::-webkit-scrollbar{display:none}.s-notifications__tab{align-items:center;background:hsla(0,0%,100%,.06);border:none;border-radius:19998rpx;color:hsla(0,0%,100%,.72);display:inline-flex;flex-shrink:0;font-size:26rpx;font-weight:500;gap:12rpx;padding:16rpx 28rpx;-webkit-tap-highlight-color:transparent}.s-notifications__tab--active{background:rgba(255,0,102,.18);box-shadow:inset 0 0 0 2rpx rgba(255,0,102,.35);color:var(--primary)}.s-notifications__tab-count{background:hsla(0,0%,100%,.1);border-radius:19998rpx;font-size:22rpx;height:36rpx;line-height:36rpx;min-width:36rpx;padding:0 10rpx;text-align:center}.s-notifications__tab--active .s-notifications__tab-count{background:rgba(255,0,102,.25)}.s-notifications__toolbar{display:flex;gap:32rpx;justify-content:flex-end;margin-bottom:24rpx}.s-notifications__toolbar-btn{background:transparent;border:none;color:var(--primary);font-size:26rpx;font-weight:600;padding:8rpx 0;-webkit-tap-highlight-color:transparent}.s-notifications__toolbar-btn:disabled{opacity:.4}.s-notifications__list{display:flex;flex-direction:column;gap:20rpx}.s-notifications__item{align-items:stretch;background:rgba(30,30,30,.9);border-radius:var(--radius-2xl);box-shadow:inset 0 0 0 2rpx hsla(0,0%,100%,.06);display:flex;gap:8rpx;position:relative;width:100%}.s-notifications__item--unread{box-shadow:inset 6rpx 0 0 var(--primary),inset 0 0 0 2rpx hsla(0,0%,100%,.06)}.s-notifications__item-main{align-items:flex-start;background:transparent;border:none;display:flex;flex:1;gap:24rpx;min-width:0;padding:28rpx 16rpx 28rpx 24rpx;text-align:left;-webkit-tap-highlight-color:transparent}.s-notifications__item-main:active{opacity:.88}.s-notifications__icon{align-items:center;border-radius:24rpx;display:flex;flex-shrink:0;height:80rpx;justify-content:center;width:80rpx}.s-notifications__icon--pindan{background:rgba(255,0,102,.15);color:var(--primary)}.s-notifications__icon--like{background:rgba(255,105,180,.15);color:#ff69b4}.s-notifications__icon--comment{background:rgba(76,201,240,.15);color:var(--secondary)}.s-notifications__icon--system{background:rgba(255,193,7,.15);color:#ffc107}.s-notifications__icon--general{background:hsla(0,0%,100%,.08);color:hsla(0,0%,100%,.72)}.s-notifications__icon--ticket{background:rgba(76,201,240,.15);color:var(--secondary)}.s-notifications__content{flex:1;min-width:0}.s-notifications__title-row{align-items:center;display:flex;gap:16rpx;justify-content:space-between}.s-notifications__title{color:#fff;font-size:30rpx;font-weight:600}.s-notifications__time{color:var(--muted-foreground);flex-shrink:0;font-size:22rpx}.s-notifications__body{color:hsla(0,0%,100%,.72);font-size:26rpx;line-height:1.45;margin-top:8rpx}.s-notifications__dot{background:var(--primary);border-radius:19998rpx;flex-shrink:0;height:16rpx;margin-top:12rpx;width:16rpx}.s-notifications__delete{align-self:center;background:transparent;border:none;color:hsla(0,0%,100%,.35);flex-shrink:0;padding:28rpx 24rpx 28rpx 12rpx;-webkit-tap-highlight-color:transparent}.s-notifications__delete:active{color:rgba(var(--destructive-rgb),.92)}.s-notifications__empty{color:var(--muted-foreground);padding:96rpx 32rpx;text-align:center}.s-notifications__empty-icon{margin:0 auto 24rpx;opacity:.5}.s-notifications__empty-title{color:hsla(0,0%,100%,.85);font-size:32rpx;font-weight:600;margin-bottom:12rpx}.s-notifications__empty-desc{font-size:26rpx}.s-notifications__loading{color:var(--muted-foreground);font-size:28rpx;padding:64rpx;text-align:center}