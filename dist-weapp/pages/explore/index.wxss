:root,page{--nut-scale-f:1;--nut-scale-font:var(--nut-scale-f,1);--nut-scale-icon:var(--nut-scale-f,1);--nut-icon-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-width:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important;--nut-icon-line-height:calc(32rpx*var(--nut-scale-icon, var(--nut-scale-f, 1)))!important}.s-top-bar{align-items:center;backdrop-filter:blur(24rpx);background:hsla(0,0%,6%,.9);display:flex;justify-content:center;padding:24rpx 32rpx;position:sticky;top:0;z-index:40}.s-top-bar--home{justify-content:space-between}.s-top-bar__actions{align-items:center;display:flex;gap:20rpx;position:absolute;right:32rpx;top:50%;transform:translateY(-50%)}.s-top-bar--home .s-top-bar__actions{position:static;transform:none}.s-top-bar__agent-btn{background:linear-gradient(90deg,#4cc9f0,#f06);border:none;border-radius:19998rpx;color:#fff;font-size:24rpx;font-weight:700;padding:12rpx 28rpx;-webkit-tap-highlight-color:transparent}.s-top-bar__agent-btn:active{opacity:.85}.s-top-bar__bell-btn{align-items:center;background:hsla(0,0%,100%,.06);border:none;border-radius:19998rpx;color:#fff;display:flex;height:72rpx;justify-content:center;width:72rpx;-webkit-tap-highlight-color:transparent;position:relative}.s-top-bar__bell-btn:active{opacity:.85}.s-top-bar__bell-badge{background:var(--primary);border-radius:19998rpx;box-shadow:0 0 0 4rpx hsla(0,0%,6%,.95);color:#fff;font-size:20rpx;font-weight:700;height:32rpx;line-height:32rpx;min-width:32rpx;padding:0 8rpx;position:absolute;right:-4rpx;text-align:center;top:-4rpx}.s-top-bar__inner{align-items:center;display:flex;gap:16rpx}.s-top-bar__icon{color:var(--secondary)}.s-top-bar__title{color:var(--foreground);font-size:36rpx;font-weight:700;letter-spacing:.06em}