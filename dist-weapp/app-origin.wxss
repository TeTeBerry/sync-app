 * Tab page shell: viewport-sized root without overflow:hidden so fixed tab bar
 * is not clipped on WeChat. Scroll areas use absolute inset above the tab bar.
 */
.s-page-with-tabbar {
  width: 100%;
  height: 100vh;
  height: 100dvh;
  position: relative;
  box-sizing: border-box;
}
